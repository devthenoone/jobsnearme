# ============================================================================
#  Copy this file to .env.local (dev) or set these as environment variables
#  on your server (production). NEVER commit real secrets.
# ============================================================================

# REQUIRED — sign the login session cookie. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# REQUIRED in production — your public site URL (used for SEO, sitemap, canonical).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# OPTIONAL — AdSense for Search (RSoC). You can instead set these from the
# admin dashboard (Settings), which is stored in the database and overrides these.
NEXT_PUBLIC_ADSENSE_PUB_ID=
NEXT_PUBLIC_RSOC_STYLE_ID=

# OPTIONAL — show the local "your keywords" preview block on posts.
# Set to "false" in production so a look-alike unit never sits next to real ads.
NEXT_PUBLIC_SHOW_KEYWORD_PREVIEW=false

# ---------------------------------------------------------------------------
# The items below are LEGACY (used only by the old /search page + clone). Safe
# to leave blank. They do not affect the live AdSense unit.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_CSE_CX=
# SERPAPI_KEY=
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
